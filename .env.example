# App URL (production — use your custom domain)
NEXT_PUBLIC_APP_URL=https://www.texasinsureprep.com

# Creem (https://www.creem.io) — Merchant of Record checkout
# Dashboard → Developers → API Key
CREEM_API_KEY=creem_test_...

# Create two one-time products, then paste their product IDs (prod_...)
CREEM_PRODUCT_UNLOCK=prod_...
CREEM_PRODUCT_PDF=prod_...

# Optional: force test API even with a live-looking key
# CREEM_TEST_MODE=true

# Aceable (or other) affiliate destination lives in src/data/catalog.ts
